{
    "name": "jelte-ten-holt/in-other-shops",
    "description": "Modular e-commerce domain packages for Laravel",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0 || ^13.0",
        "filament/filament": "^5.0",
        "opgginc/laravel-mcp-server": "^2.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpunit/phpunit": "^11.0 || ^12.0",
        "mockery/mockery": "^1.6"
    },
    "suggest": {
        "stripe/stripe-php": "Install to enable the Stripe payment gateway driver (^15.0 || ^16.0)."
    },
    "autoload": {
        "psr-4": {
            "InOtherShops\\Commerce\\": "src/Commerce/",
            "InOtherShops\\Currency\\": "src/Currency/",
            "InOtherShops\\FlowChain\\": "src/FlowChain/",
            "InOtherShops\\Inventory\\": "src/Inventory/",
            "InOtherShops\\Location\\": "src/Location/",
            "InOtherShops\\Logging\\": "src/Logging/",
            "InOtherShops\\Media\\": "src/Media/",
            "InOtherShops\\Payment\\": "src/Payment/",
            "InOtherShops\\Pricing\\": "src/Pricing/",
            "InOtherShops\\Shipping\\": "src/Shipping/",
            "InOtherShops\\Agent\\": "src/Agent/",
            "InOtherShops\\Storefront\\": "src/Storefront/",
            "InOtherShops\\Taxonomy\\": "src/Taxonomy/",
            "InOtherShops\\Translation\\": "src/Translation/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "InOtherShops\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-text"
    },
    "extra": {
        "laravel": {
            "providers": [
                "InOtherShops\\Currency\\CurrencyServiceProvider",
                "InOtherShops\\Translation\\TranslationServiceProvider",
                "InOtherShops\\Logging\\LoggingServiceProvider",
                "InOtherShops\\Location\\LocationServiceProvider",
                "InOtherShops\\Media\\MediaServiceProvider",
                "InOtherShops\\Taxonomy\\TaxonomyServiceProvider",
                "InOtherShops\\Pricing\\PricingServiceProvider",
                "InOtherShops\\Inventory\\InventoryServiceProvider",
                "InOtherShops\\Shipping\\ShippingServiceProvider",
                "InOtherShops\\Payment\\PaymentServiceProvider",
                "InOtherShops\\Payment\\Drivers\\Stripe\\StripeGatewayServiceProvider",
                "InOtherShops\\Commerce\\CommerceServiceProvider",
                "InOtherShops\\FlowChain\\FlowChainServiceProvider",
                "InOtherShops\\Storefront\\StorefrontServiceProvider",
                "InOtherShops\\Agent\\AgentServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
